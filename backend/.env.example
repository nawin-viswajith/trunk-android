CORS_ORIGINS=*

# Crash-report prompt (see app/services/github_service.py) - fine-grained
# GitHub PAT scoped to "Issues: read and write" on GITHUB_REPO only.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Must match EXPO_PUBLIC_APP_SHARED_SECRET in the app build - stops
# opportunistic abuse of /api/support/report from anyone hitting the URL
# directly (not a determined attacker who decompiles the APK). Leaving this
# unset disables the check - only acceptable for local dev.
APP_SHARED_SECRET=
